---
layout: base.njk
---
<article class="module">
  <p class="crumb"><a href="/">← All modules</a></p>
  <h1>{{ title }}</h1>
  <p class="lead">{{ blurb }}</p>

  {{ content | safe }}

  <section class="quiz-section" id="quiz-root" data-slug="{{ slug }}">
    <h2>Practice questions</h2>
    <p class="lead">Pick an answer to get instant feedback. Your best score is saved in this browser only.</p>
    <div id="quiz"></div>
  </section>
</article>
<script src="/assets/js/quiz.js"></script>
